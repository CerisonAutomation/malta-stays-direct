# ==============================================================
# Malta Stays Direct - Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ==============================================================

# ----- Guesty Booking Engine API -----
# Server-side only - never expose to browser
GUESTY_BEAPI_KEY=your_guesty_beapi_key_here
GUESTY_ACCOUNT_ID=your_guesty_account_id_here

# ----- Stripe (payment tokenization) -----
# Public key is safe to expose
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# Server-side only
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ----- Site configuration -----
NEXT_PUBLIC_SITE_URL=https://maltastaysdirect.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key

# ----- Analytics -----
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ----- Contact details -----
NEXT_PUBLIC_CONTACT_PHONE=+35679790202
NEXT_PUBLIC_CONTACT_EMAIL=info@christianopropertymanagement.com
NEXT_PUBLIC_WHATSAPP=35679790202

# ----- Feature flags -----
NEXT_PUBLIC_INSTANT_BOOK_ENABLED=true
NEXT_PUBLIC_ECO_TAX_RATE=0.50
